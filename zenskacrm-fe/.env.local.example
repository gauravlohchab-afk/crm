# ═══════════════════════════════════════════════════════
#  Zenska CRM — Frontend Environment Variables
#  Copy this file to ".env.local" in the frontend root.
#  NEVER commit your real .env.local to git.
# ═══════════════════════════════════════════════════════

# URL of your backend API — no trailing slash.
# Must match the PORT in your backend .env (default: 8000).

# ── Local development ──
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Production (examples) ──
# NEXT_PUBLIC_API_URL=https://api.zenska.ph
# NEXT_PUBLIC_API_URL=https://zenska-crm-backend.onrender.com
